{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "rentagent-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "examples/rentagent_vn/frontend"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "rentagent-api",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "examples.rentagent_vn.run_all"],
      "port": 8000
    },
    {
      "name": "zalo-service",
      "runtimeExecutable": "node",
      "runtimeArgs": ["examples/rentagent_vn/zalo-service/index.js"],
      "port": 8001
    }
  ]
}
